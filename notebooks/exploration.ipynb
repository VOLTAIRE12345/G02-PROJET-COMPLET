   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Chargement du dataset IMDb (D01)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from data_loader import load_imdb_subset, get_dataloaders\n",
    "\n",
    "subsets = load_imdb_subset(\n",
    "    num_train_per_class=300,\n",
    "    num_val_per_class=100,\n",
    "    num_test_per_class=150,\n",
    ")\n",
    "\n",
    "print('\\nTaille des splits :')\n",
    "for split, data in subsets.items():\n",
    "    lengths = [len(ex['text'].split()) for ex in data]\n",
    "    print(f'  {split:>12s} | {len(data):4d} ex. | '\n",
    "          f'longueur moy. : {np.mean(lengths):.0f} mots | '\n",
    "          f'max : {max(lengths)} mots')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Exemples d'avis ────────────────────────────────────────────────────────\n",
    "for i in range(2):\n",
    "    ex = subsets['train'][i]\n",
    "    label_str = 'POSITIF ✓' if ex['label'] == 1 else 'NEGATIF ✗'\n",
    "    print(f'--- Exemple {i+1} [{label_str}] ---')\n",
    "    print(ex['text'][:300], '...')\n",
    "    print()"
   ]
