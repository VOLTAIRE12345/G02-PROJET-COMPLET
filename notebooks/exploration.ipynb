   "metadata": {},
   "source": ["## 3. Tokenisation BERT"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from model_setup import get_model_and_tokenizer\n",
    "\n",
    "# Charger seulement le tokenizer (rapide)\n",
    "from transformers import AutoTokenizer\n",
    "tokenizer = AutoTokenizer.from_pretrained('bert-base-uncased')\n",
    "\n",
    "# Comparer mots vs tokens\n",
    "examples = subsets['train'][:5]\n",
    "print('Comparaison mots / tokens BERT :')\n",
    "print(f'{\"Mots\":>6s}  {\"Tokens\":>6s}  {\"Ratio\":>6s}  Texte')\n",
    "print('-' * 70)\n",
    "for ex in examples:\n",
    "    n_mots   = len(ex['text'].split())\n",
    "    n_tokens = len(tokenizer.encode(ex['text']))\n",
    "    print(f'{n_mots:6d}  {n_tokens:6d}  {n_tokens/n_mots:6.2f}  '\n",
    "          f'{ex[\"text\"][:60]}...')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Test d'un batch ────────────────────────────────────────────────────────\n",
    "loaders = get_dataloaders(subsets, tokenizer, batch_size=16, max_length=200)\n",
    "batch   = next(iter(loaders['train']))\n",
    "\n",
    "print('Dimensions d\\'un batch :')\n",
    "for k, v in batch.items():\n",
    "    print(f'  {k:20s} : {v.shape}')\n",
    "print(f'\\nLabels (extrait) : {batch[\"labels\"][:8].tolist()}')"
   ]
